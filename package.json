{
	"name": "just-git",
	"version": "1.2.10",
	"description": "Pure TypeScript git implementation: virtual filesystem client and embeddable server.",
	"keywords": [
		"agent",
		"embedded",
		"git",
		"git-server",
		"in-memory",
		"isomorphic",
		"just-bash",
		"multi-agent",
		"sandbox",
		"smart-http",
		"typescript",
		"virtual-filesystem"
	],
	"homepage": "https://github.com/blindmansion/just-git",
	"license": "MIT",
	"author": "blindmansion",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/blindmansion/just-git.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js"
		},
		"./repo": {
			"types": "./dist/repo/index.d.ts",
			"import": "./dist/repo/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"size": "tsup && bun -e \"const{gzipSync}=require('zlib'),{readFileSync}=require('fs'),b=readFileSync('dist/index.js'),g=gzipSync(b);console.log('dist/index.js  '+((b.length/1024).toFixed(1))+' kB');console.log('gzipped        '+((g.length/1024).toFixed(1))+' kB')\"",
		"prepublishOnly": "bun run build",
		"check": "bunx tsc --noEmit && bunx tsc --noEmit -p test/tsconfig.json && oxfmt && oxlint --fix",
		"oracle": "bun test/oracle/cli.ts",
		"sandbox": "bun scripts/sandbox.ts",
		"knip": "knip",
		"knip:prod": "knip --config knip-production.json",
		"gen-docs": "bun run scripts/gen-lib-reference.ts > docs/FILE_REFERENCE.md && bun run scripts/gen-cli-help.ts > docs/CLI.md",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "bun run build && changeset publish"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "latest",
		"@types/node": "^25.4.0",
		"@types/pg": "^8.18.0",
		"better-sqlite3": "^12.8.0",
		"just-bash": "^2.14.0",
		"knip": "^5.86.0",
		"oxfmt": "^0.38.0",
		"oxlint": "^1.53.0",
		"pg": "^8.20.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
